# 孩子课外课程表助手 - 环境变量配置
# 复制此文件为 .env 并填写实际值

# ==================== 通知配置 ====================

# 通知方式: serverchan | aliyun | mock
NOTIFIER_TYPE=serverchan

# Server 酱配置 (https://sct.ftqq.com/)
# 多个 SendKey 用逗号分隔
SERVERCHAN_SENDKEYS=SCTxxxxxxxxxxxxxxxxxxxxxxxxxxxxx,SCTyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# 阿里云短信配置 (可选)
ALIYUN_ACCESS_KEY_ID=your_access_key_id
ALIYUN_ACCESS_KEY_SECRET=your_access_key_secret
ALIYUN_TEMPLATE_CODE=SMS_xxxxxxxxx
ALIYUN_SIGN_NAME=your_sign_name

# ==================== AI 配置 ====================

# DashScope API Key (通义千问)
DASHSCOPE_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL_TEXT=qwen-max-latest
DASHSCOPE_MODEL_IMAGE=qwen-vl-max-latest
